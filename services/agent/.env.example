# ── Required ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Onchain execution (Base Sepolia) ──────────────────────────────────────────
# Without these, execution falls back to simulation automatically.

# Private key of the agent wallet (must be funded with Base Sepolia ETH)
AGENT_PRIVATE_KEY=0x...

# Base Sepolia RPC endpoint — the public endpoint works fine for demos
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ── Destination wallet addresses (optional overrides) ─────────────────────────
# Defaults are pre-set to well-known testnet addresses.
# Override before the demo if you want transfers going to your own wallets.

GHANA_WALLET=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
NIGERIA_WALLET=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC
KENYA_WALLET=0x90F79bf6EB2c4f870365E785982E1f101E93b906
SAVINGS_WALLET=0x15d34AAf54267DB7D7c367839AAf71A00a2C6A65

# ── Optional ───────────────────────────────────────────────────────────────────
PORT=8000
